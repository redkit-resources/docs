        <mxCell id="xPnRs9-hT7Y3agPohjy0-58" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=3;strokeColor=light-dark(#D857D8,#FF66FF);fillColor=light-dark(#E6E6E6,#1E2129);" value="" vertex="1">
          <mxGeometry height="180" width="460" x="140" y="-140" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-60" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Spawn, Community, Action Points, Job Trees, Reactions&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;Populating the world and scheduling: who exists, where they appear and what high-level task they are busy with.&amp;nbsp;&lt;/div&gt;&lt;div&gt;Creates the NPC and sets up its behavior tree.&lt;br&gt;&lt;br&gt;&amp;nbsp;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="350" x="195" y="100" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;Player&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;i&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;Input + state machines CR4Player&lt;/span&gt;&lt;br&gt;&lt;/i&gt;&lt;br&gt;&lt;p style=&quot;box-sizing: border-box; margin: 0px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;The player has no tree. Input and the global state machine with its own states decide; it sits in the stack below, right at execution.&lt;/p&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="210" x="380" y="322.5" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-62" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="&lt;div&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Actor Actions &amp;amp; Movement bridge&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&quot;One active action per NPC&quot;. Turns requests into animgraph control. The bridge between &quot;What to do&quot; and &quot;How to do it&quot;. Practically not used for the player.&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="350" x="195" y="565" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-63" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Movement&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;i&gt;Movement, steering, locomotion&lt;/i&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;p style=&quot;box-sizing: border-box; margin: 0px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;Computes speed and direction per frame, keeps on the navmesh, reconciles root motion with the desired movement.&lt;/p&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="190" x="165" y="780" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Navigation&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;i&gt;Pathfinding, pathlib&lt;/i&gt;&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;p style=&quot;box-sizing: border-box; margin: 0px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;Navmesh + navgraph, route plotting.&lt;/p&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="190" x="395" y="760" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-65" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;Behavior Graphs&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;br&gt;&lt;p style=&quot;box-sizing: border-box; margin: 0px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;Animgraph, a state machine for animations. A network of nodes receiving variables and events from scripts/trees.&lt;/p&gt;&lt;div class=&quot;cls&quot; style=&quot;box-sizing: border-box; margin-top: 9px; display: flex; flex-wrap: wrap; gap: 5px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 13px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="185" x="165" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-66" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;Animation System&lt;br&gt;&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;font style=&quot;&quot;&gt;&lt;br&gt;&lt;p style=&quot;box-sizing: border-box; margin: 0px; font-family: ui-sans-serif, system-ui, -apple-system, &amp;quot;Segoe UI&amp;quot;, Roboto, sans-serif;&quot;&gt;Computes the pose into bones, extracts root motion and sends animation events.&lt;/p&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="190" x="395" y="1000" as="geometry" />
        </mxCell>
        <mxCell id="xPnRs9-hT7Y3agPohjy0-67" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Helvetica;fontSize=12;fontColor=default;" value="&lt;div&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Scripting &amp;amp; State Machines&lt;br&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Witcher Script hosts every object above and receives OnSpawned / OnTick&amp;nbsp; / OnAnimEvent, engine events and graph notifications. For the player it is also the main source of decision-making (it replaces the decision layer).&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="350" x="195" y="-115" as="geometry" />
        </mxCell>
